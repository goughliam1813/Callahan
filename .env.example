# Callahan CI — Environment Configuration
# Copy this to .env and fill in your values

# ─── Core ─────────────────────────────────────────────────────────────────────
PORT=8080
DB_PATH=/data/callahan.db
DATA_DIR=/data
JWT_SECRET=change-me-to-a-random-secret-in-production

# ─── LLM Configuration ────────────────────────────────────────────────────────
# Set at least one. Callahan tries them in order: anthropic → openai → groq → ollama

# Anthropic Claude (recommended - most capable)
ANTHROPIC_API_KEY=

# OpenAI GPT-4
OPENAI_API_KEY=

# Google Gemini
GOOGLE_API_KEY=

# Groq (fast, has free tier)
GROQ_API_KEY=

# Ollama (local, no internet required)
OLLAMA_URL=http://localhost:11434
# To use: docker-compose --profile with-ollama up -d
# Then pull a model: docker exec callahan-ollama ollama pull llama3.2

# Default provider and model (auto-detected if not set)
LLM_PROVIDER=anthropic
LLM_MODEL=claude-3-5-sonnet-20241022

# ─── Git Providers (OAuth) ────────────────────────────────────────────────────
# GitHub OAuth App (create at: https://github.com/settings/developers)
GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=

# GitLab OAuth App
GITLAB_CLIENT_ID=
GITLAB_CLIENT_SECRET=

# ─── Feature Flags ────────────────────────────────────────────────────────────
TELEMETRY_ENABLED=false
DEV_MODE=false
